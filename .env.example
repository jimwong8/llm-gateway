# ============================================
# LLM Gateway — 环境变量配置模板
# 复制此文件为 .env 并修改实际值
# ============================================

# ---- 应用基础配置 ----
APP_ENV=production
APP_NAME=llm-gateway
APP_PORT=8080

# ---- 数据库 ----
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DSN=postgres://llmadmin:CHANGE_ME_STRONG_PASSWORD@postgres:5432/llmgateway?sslmode=disable

# ---- Redis ----
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- 缓存 ----
L1_CACHE_TTL_SECONDS=600

# ---- 语义缓存 (Qdrant) ----
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.80
SEMANTIC_VECTOR_SIZE=64
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=CHANGE_ME
QDRANT_COLLECTION=semantic_cache_v1

# ---- 记忆 ----
MEMORY_ENABLED=true
MEMORY_MAX_ITEMS=3

# ---- 默认路由 ----
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-4o-mini

# ---- Mock 模式 (开发/测试时设为 true) ----
MOCK_MODE=false

# ---- OpenAI ----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_TIMEOUT_SEC=120

# ---- XSTX ----
XSTX_BASE_URL=https://api.xstx.info/v1
XSTX_API_KEY=
XSTX_TIMEOUT_SEC=120

# ---- Anthropic ----
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_TIMEOUT_SEC=120

# ---- 审计 ----
AUDIT_LOG_ENABLED=true
AUDIT_RETENTION_DAYS=90

# ---- 计费 ----
BILLING_ENABLED=true

# ---- 配额 ----
TENANT_RPM=60
DEFAULT_API_KEY_RPM=60

# ---- 管理 API ----
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY

# ---- JWT ----
JWT_SECRET=CHANGE_ME_JWT_SECRET_AT_LEAST_32_CHARACTERS

# ---- 提供者熔断 ----
PROVIDER_MAX_RETRIES=1
PROVIDER_FAILURE_THRESHOLD=2
PROVIDER_OPEN_SECONDS=30
PROVIDER_HEALTH_TIMEOUT_SEC=5

# ---- 模型治理 ----
MODEL_GOVERNANCE_ENABLED=true
MODEL_GOVERNANCE_CACHE_TTL_SECONDS=60
MODEL_GOVERNANCE_ROLLOUT_MAX_ERROR_RATE=0.02
MODEL_GOVERNANCE_ROLLOUT_MAX_P95_MS=1200
MODEL_GOVERNANCE_ROLLOUT_MAX_FALLBACK_RATE=0.15
MODEL_GOVERNANCE_MIN_SAMPLE_COUNT=200

# ---- 回退路由 ----
FALLBACK_MAX_DEPTH=3
FALLBACK_MIN_SCORE_RATIO=0.5

# ---- GitHub OAuth (可选) ----
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- SMTP 邮件 (可选) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
