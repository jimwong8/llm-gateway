# ============================================
# .dockerignore - LLM Gateway
# 减少构建上下文体积，加速 docker build
# ============================================

# --- VCS ---
.git
.gitignore
.gitattributes

# --- IDE / Editor ---
.idea
.vscode
*.swp
*.swo
*~
.project
.settings

# --- OS ---
.DS_Store
Thumbs.db

# --- Node / Frontend ---
node_modules
web/admin/node_modules
web/admin/dist
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Go ---
vendor
*.test
*.out
coverage.txt
coverage.html

# --- Build artifacts ---
dist
bin
server
*.tar
*.exe
*.dll
*.so

# --- Temp / Sync ---
tmp_sync*
tmp_sync_remote
tmp_sync_runtime

# --- Logs ---
*.log
logs/

# --- Environment (NEVER bake into image) ---
.env
.env.*
!.env.example

# --- Docs (not needed in runtime image) ---
*.md
LICENSE
docs/

# --- CI / GitHub ---
.github
.gitlab-ci.yml
.travis.yml

# --- Docker (avoid recursive) ---
Dockerfile*
docker-compose*.yml
.dockerignore

# --- Scripts (not needed in image) ---
scripts/
benchmark/
loadtest/

# --- Misc ---
*.orig
*.bak
*.tmp
.envrc
direnv/
